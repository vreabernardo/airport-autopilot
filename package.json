{
  "name": "airport-autopilot",
  "version": "1.0.0",
  "private": true,
  "description": "A 60 Hz receding-horizon multi-agent controller for Airport Simulator.",
  "type": "module",
  "scripts": {
    "setup": "playwright install chromium",
    "start": "node runner.mjs",
    "start:background": "./start-runner.sh",
